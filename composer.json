{
    "name": "jp3cki/yii2-jp-postalcode-validator",
    "description": "Postal code validator for Yii Framework2",
    "license": "MIT",
    "type": "yii2-extension",
    "keywords": [
        "yii2",
        "extension",
        "validator",
        "postalcode",
        "zipcode",
        "japan"
    ],
    "authors": [
        {
            "name": "AIZAWA Hina",
            "email": "hina@fetus.jp"
        }
    ],
    "require": {
        "php": ">= 8.2.0",
        "ext-json": "*",
        "ext-pcre": "*",
        "ext-zlib": "*",
        "symfony/polyfill-php83": "^1.37.0",
        "yiisoft/yii2": "~2.0.54"
    },
    "require-dev": {
        "ext-curl": "*",
        "ext-mbstring": "*",
        "ext-zip": "*",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2.0",
        "ergebnis/composer-normalize": "^2.51.0",
        "erickskrauch/phpstan-yii2": "dev-master",
        "jp3cki/coding-standard": "^2.0.0",
        "php-curl-class/php-curl-class": "^13.0.0",
        "phpunit/phpunit": "^11.5.55",
        "squizlabs/php_codesniffer": "^4.0.1"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "autoload": {
        "psr-4": {
            "jp3cki\\yii2\\jppostalcode\\": "src",
            "jp3cki\\yii2\\jppostalcode\\test\\": "test/src"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "yiisoft/yii2-composer": true
        },
        "platform": {
            "php": "8.2.30"
        },
        "sort-packages": true
    },
    "extra": {
        "bootstrap": "jp3cki\\yii2\\jppostalcode\\internal\\PostalCodeBootstrap"
    }
}
